# Local PostgreSQL example:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ligtas"

# Hosted PostgreSQL / Neon example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
MFA_ENABLED=true

# CORS / frontend URLs
ALLOWED_ORIGINS="http://localhost:5173"
PASSWORD_RESET_FRONTEND_URL="http://localhost:5173"

# Report scanning
AI_ENABLED=true
RULE_FALLBACK_ENABLED=true
AI_PROVIDER="ollama"

# PDF text extraction
# Default is the existing Node/pdf-parse path. Use pymupdf only when Python dependencies are installed.
PDF_EXTRACTOR_PROVIDER="pdf_parse"
# PYMUPDF_PYTHON_BIN="python"
# PYMUPDF_EXTRACT_SCRIPT_PATH="scripts/pymupdf_extract.py"

# Local Ollama AI scanning
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3:8b-instruct-q4_0"
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_CHARS_PER_CHUNK=3000

# Optional OpenAI cloud scanning for hosted evaluation.
# Set AI_PROVIDER="openai" and provide a real key through deployment secrets.
# OPENAI_API_KEY="replace-with-openai-key"
# OPENAI_MODEL="gpt-4.1-mini"
# OPENAI_TIMEOUT_MS=120000
# OPENAI_MAX_CHARS_PER_CHUNK=12000

# Email
# Handover default: disabled. The client can adapt this to Resend or SMTP.
EMAIL_PROVIDER=disabled

# Resend example:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY="replace-with-resend-key"
# SMTP_FROM="noreply@example.com"

# SMTP example:
# If EMAIL_PROVIDER=smtp, fill all SMTP_* variables.
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS="your-sendgrid-api-key"
# SMTP_FROM="verified-sender@yourdomain.com"

# TLS (SMTP only): keep default true in production.
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# Optional SMTP debug: SMTP_DEBUG=1

# Optional login CAPTCHA with Cloudflare Turnstile.
# LOGIN_CAPTCHA_PROVIDER=turnstile
# LOGIN_TURNSTILE_SECRET_KEY="replace-with-turnstile-secret"
# LOGIN_CAPTCHA_AFTER_LOCKOUTS=2

# Optional operational limits.
# AUTH_AUDIT_EVENT_LIMIT=200
# EMAIL_SHARE_MAX_PER_HOUR=10
# MAX_REPORT_FILE_SIZE_BYTES=52428800
# REPORT_SESSION_TTL_HOURS=4
